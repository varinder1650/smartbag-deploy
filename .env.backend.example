# ============================================
# SmartBag Backend — Environment Variables
# ============================================
# Copy to .env.backend and fill in production values

# Environment
ENVIRONMENT=Production

# Database
MONGO_URI=mongodb://mongo:27017
DB_NAME=smartbag

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=100
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# JWT
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Security
ALLOWED_ORIGINS=https://admin.yourdomain.com,https://yourdomain.com
BCRYPT_ROUNDS=10
MAX_CART_ITEMS_PER_PRODUCT=100
ENABLE_RATE_LIMITING=true

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=your_email@gmail.com
FROM_NAME=SmartBag

# Ola Maps
OLA_KRUTRIM_API_KEY=your_ola_api_key
OLA_BASE_URL=https://api.olamaps.io/places/v1

# Performance
DB_CONNECTION_POOL_SIZE=10
API_RATE_LIMIT_PER_MINUTE=1000
RATE_LIMIT_BURST=10
SLOW_QUERY_THRESHOLD=1.0
ENABLE_QUERY_CACHE=true
ENABLE_MULTI_LAYER_CACHE=true

# Cache TTL (seconds)
CACHE_TTL_CART=1800
CACHE_TTL_PRODUCT_DETAIL=3600
CACHE_TTL_PRODUCT_LIST=600
CACHE_TTL_CATEGORIES=7200
CACHE_TTL_BRANDS=7200
CACHE_TTL_USER_ORDERS=900
CACHE_TTL_SHOP_STATUS=300
CACHE_TTL_INVENTORY=60

# Monitoring
LOG_LEVEL=INFO
ENABLE_PROFILING=false
SENTRY_DSN=

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# Search
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ENABLE_ELASTICSEARCH=false
ELASTICSEARCH_INDEX_PREFIX=smartbag

# Background Tasks
ENABLE_CELERY=false
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Orders
ORDER_SIGNATURE_SECRET=change_me_strong_secret

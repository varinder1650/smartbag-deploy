# ============================================
# SmartBag Admin Backend — Environment Variables
# ============================================
# Copy to .env.admin-backend and fill in production values

# Environment
ENVIRONMENT=Production

# MongoDB
MONGO_URI=mongodb://mongo:27017
DB_NAME=smartbag

# JWT
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL (set via docker-compose.prod.yml, but can override here)
# POSTGRES_URL=postgresql+asyncpg://smartbag:password@postgres:5432/smartbag_inventory

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=20

# Background Tasks
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Monitoring
LOG_LEVEL=INFO

# Cache Settings
DEFAULT_CACHE_TTL=300
TRENDING_CACHE_TTL=3600
PERSONALIZED_CACHE_TTL=7200

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Ola Maps
OLA_KRUTRIM_API_KEY=your_ola_api_key
OLA_BASE_URL=https://api.olamaps.io/places/v1

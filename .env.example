# ============================================
# SmartBag — Root Docker Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# These are used by docker-compose for infrastructure services

# Domain (used in nginx prod config)
DOMAIN=yourdomain.com

# PostgreSQL
POSTGRES_USER=smartbag
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=smartbag_inventory

# MongoDB (production)
MONGO_DB=smartbag
MONGO_ROOT_USER=smartbag_admin
MONGO_ROOT_PASSWORD=change_me_mongo_password

# Redis (production - set empty for dev)
REDIS_PASSWORD=change_me_redis_password
